{
  "expo": {
    "name": "Yo Hit Radio",
    "slug": "yo-hit-radio",
    "version": "1.0.7",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4B1E78"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.Natively",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "audio"
        ],
        "NSCameraUsageDescription": false,
        "NSPhotoLibraryUsageDescription": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4B1E78"
      },
      "splash": {
        "image": "./assets/images/logo 192 (1).png",
        "resizeMode": "contain",
        "backgroundColor": "#4B1E78"
      },
      "package": "com.yohitradio.app",
      "googleServicesFile": "./google-services.json",
      "versionCode": 8,
      "permissions": [
        "INTERNET",
        "MODIFY_AUDIO_SETTINGS",
        "VIBRATE",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "POST_NOTIFICATIONS",
        "WAKE_LOCK"
      ],
      "blockedPermissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      [
        "onesignal-expo-plugin",
        {
          "mode": "development"
        }
      ]
    ],
    "scheme": "yohitradio",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://ggjfh5vjvuut7kh3tnnefceazjf2q6jg.app.specular.dev",
      "oneSignalAppId": "41c0200e-69a3-4e4d-bc0d-0a53d0f6e65a"
    },
    "icon": "./assets/icon.png"
  }
}